# =============================================================================
# Predictrix mobile app (Expo) — environment template
# Copy to `.env` (gitignored).
#
# WARNING: every EXPO_PUBLIC_* value is BUNDLED INTO THE APP BINARY and is
# NOT secret. Never put private keys, passwords, or tokens here.
# Full reference: ../docs/CONFIGURATION.md
# =============================================================================

# Backend URL used by RELEASE builds (default: Fly.io).
# For an Azure release: https://<your-app>.azurewebsites.net
EXPO_PUBLIC_API_BASE_URL=https://predictrix-api.fly.dev

# Local DEV only — your PC's LAN IP so a physical device can reach the backend.
# Android emulator uses 10.0.2.2 automatically; iOS sim / web use localhost.
# EXPO_PUBLIC_LOCAL_API_HOST=192.168.1.50
