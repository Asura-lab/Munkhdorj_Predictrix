# =============================================================================
# Predictrix backend — environment template
# Copy to `config/.env` and fill in. NEVER commit the real .env.
# Production secrets must come from the platform secret manager (Fly / Azure).
# Full reference: docs/CONFIGURATION.md
# =============================================================================

# --- Core secrets (required in production) -----------------------------------
# Dev fallback: mongodb://localhost:27017/users_db (used only when unset)
MONGO_URI=CHANGE_ME
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# --- Email (Flask-Mail): needed for verification & password reset ------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME          # Gmail: use an App Password (requires 2FA)
MAIL_DEFAULT_SENDER=CHANGE_ME

# --- Runtime -----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=5000
DEBUG=True
LOG_LEVEL=INFO
# APP_ENV=development            # set production/staging to force prod mode
# APP_PROCESS_ROLE=all           # api | worker | all
# BACKGROUND_WORKERS_ENABLED=false

# Local convenience (keep false unless you know why)
ALLOW_LOCAL_DOTENV=false
STRICT_RUNTIME_SECRETS=false
TRUSTED_PROXY_COUNT=1

# --- JWT / session -----------------------------------------------------------
JWT_ISSUER=predictrix-api
JWT_AUDIENCE=predictrix-mobile
ACCESS_TOKEN_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=30

# --- CORS / rate limiting ----------------------------------------------------
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# ALLOW_ALL_CORS=false           # dev only — allow every origin
AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_REDIS_URL=          # set a Redis URL for multi-instance prod

# --- Feature flags / governance (safe defaults) ------------------------------
# ALLOW_DEMO_AUTH_CODES=false        # returns OTP in response — NEVER in prod
# ALLOW_TEST_NOTIFICATION_ENDPOINT=false
# MODEL_CONTRACT_REQUIRED=true
# ANALYSIS_CIRCUIT_FAIL_THRESHOLD=3
# ANALYSIS_CIRCUIT_COOLDOWN_SECONDS=180

# --- External data (optional; yfinance is primary and needs no key) ----------
ALPHAVANTAGE_API_KEY=

# --- AI / LLM (optional): Google Gemini market-analysis narrative -------------
# Add up to GEMINI_API_KEY_21 for the rotation pool. Leave empty to disable LLM.
# GEMINI_SAFETY_MODE=balanced
# ALLOW_EXTERNAL_LLM_FALLBACK=false
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
